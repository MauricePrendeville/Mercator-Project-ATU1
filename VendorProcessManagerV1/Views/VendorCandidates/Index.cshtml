@model IEnumerable<VendorProcessManagerV1.Models.VendorCandidate>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Vendor Candidates</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["VendorNameSort"]">
                    Vendor Name</a>
            </th>
            <th>
                Active Instances
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["CategorySort"]">
                    Category</a>
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["CreateDateSort"]">
                    Create Date</a>
            </th>            
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["OwnerSort"]">
                    Owner</a>
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["TermsSort"]">
                    Payment Terms</a>
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                    @if (item.ProcessInstances != null && item.ProcessInstances.Any())
                    {
                        var activeCount = item.ProcessInstances
                        .Count(i => i.Status == ProcessInstanceStatus.InProgress);
                        var totalCount = item.ProcessInstances.Count; 
                        <span class="text-muted">@activeCount active / @totalCount total</span>
                    }else
                    {
                        <span class="text-muted">No instances</span>
                    }
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Category)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CreateDate)
            </td>            
            <td>
                @item.Owner?.FirstName @item.Owner?.LastName
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.PaymentTerms)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
