@model VendorProcessManagerV1.ViewModels.VendorCandidateIndexViewModel

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Vendor Candidates</h2>

<p>
    <a asp-action="Create" class="btn btn-success mb-3">Add Vendor Candidate</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@Model.VendorNameSort">Vendor Name
                    <i class="bi @(Model.CurrentSort =="name_asc" ? "bi-arrow-up-square" :
                                    Model.CurrentSort == "name_desc" ? "bi-arrow-down-square" :
                                    "bi-arrow-down-up text-muted")"></i></a>
            </th>
            <th>
                Active Instances
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@Model.CategorySort">Category
                    <i class="bi @(Model.CurrentSort =="category_asc" ? "bi-arrow-up-square" :
                                   Model.CurrentSort == "category_desc" ? "bi-arrow-down-square" :
                                   "bi-arrow-down-up text-muted")"></i></a>
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@Model.DateSort">Create Date
                    <i class="bi @(Model.CurrentSort =="date_asc" ? "bi-arrow-up-square" :
                                   Model.CurrentSort == "date_desc" ? "bi-arrow-down-square" :
                                   "bi-arrow-down-up text-muted")"></i></a>
            </th>            
            <th>
                <a asp-action="Index" asp-route-sortOrder="@Model.OwnerSort">Owner
                    <i class="bi @(Model.CurrentSort =="owner_asc" ? "bi-arrow-up-square" :
                                   Model.CurrentSort == "owner_desc" ? "bi-arrow-down-square" :
                                   "bi-arrow-down-up text-muted")"></i></a>
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@Model.TermsSort">
                    Payment Terms
                    <i class="bi @(Model.CurrentSort =="terms_asc" ? "bi-arrow-up-square" :
                                   Model.CurrentSort == "terms_desc" ? "bi-arrow-down-square" :
                                   "bi-arrow-down-up text-muted")"></i>
                </a>
            </th>
            <th width="130px"></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.VendorCandidates) {
        <tr>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id">@item.Name</a>
            </td>
            <td>
                    @if (item.ProcessInstances != null && item.ProcessInstances.Any())
                    {
                        var activeCount = item.ProcessInstances
                        .Count(i => i.Status == ProcessInstanceStatus.InProgress);
                        var totalCount = item.ProcessInstances.Count; 
                        <span class="text-muted">@activeCount active / @totalCount total</span>
                    }else
                    {
                        <span class="text-muted">No instances</span>
                    }
            </td>
            <td>
                @item.Category
            </td>
            <td>
                @item.CreateDate
            </td>            
            <td>
                @item.Owner?.FirstName @item.Owner?.LastName
            </td>
            <td>
                @item.PaymentTerms
            </td>
            <td width="130px">
               <a asp-action="Edit" asp-route-id="@item.Id" title="Edit"><i class="bi bi-pencil-fill"></i></a> |
               <a asp-action="Details" asp-route-id="@item.Id" title="Details"><i class="bi bi-card-checklist"></i></a> |
               <a asp-action="Delete" asp-route-id="@item.Id" title="Delete"><i class="bi bi-trash3-fill"></i></a>
            </td>
        </tr>
}
    </tbody>
</table>
