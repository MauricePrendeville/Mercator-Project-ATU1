@model VendorProcessManagerV1.Models.ProcessTemplate

@{
    ViewData["Title"] = "Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Details</h1>

<h2>@Model.Name</h2>
<p>@Model.Description</p>
<p>Created by: @Model.Creator.FirstName @Model.Creator.LastName</p>
<hr />
<div>
    <h4>Tasks</h4>
    <a asp-controller="ProcessTemplateTasks" 
        asp-action="Create" 
        asp-route-templateId="@Model.Id"
        class="btn btn-primary btn-sm">Add Task</a>
</div>
<div>
    <h4>ProcessTemplate</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Category)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Category)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Creator)
        </dt>
        <dd class = "col-sm-10">
            @* @Html.DisplayFor(model => model.Creator) *@
            @Model.Creator.FirstName @Model.Creator.LastName
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.CreateDate)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.CreateDate)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.IsActive)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.IsActive)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Version)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Version)
        </dd>
    </dl>
</div>
<div> 
    <a asp-action="StartInstance" 
        asp-controller="ProcessTemplates" 
        asp-route-id="@Model.Id" 
        class="btn btn-success">Start Instance
    </a>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-list-check"></i> Step Templates</h5>
        <a asp-controller="ProcessTemplateTasks" asp-action="Create" asp-route-templateId="@Model?.Id" class="btn btn-sm btn-success">
            <i class="bi bi-plus-circle"></i> Add Task
        </a>
    </div>
</div>

@if (Model.Tasks != null && Model.Tasks.Any())
{
    @foreach (var task in Model.Tasks.OrderBy(t => t.SortOrder))
    {
        <div class="card-mb-2">
            <div class="card-header d-flex justify-content-between align-items-center">
            <span>@task.Title</span>
                <div>
                    <a asp-controller="ProcessTemplateTasks"
                    asp-action="Edit"
                    asp-route-id="@task.Id"
                    class="btn btn-sm btn-outline-primary">Edit</a>
        
                    <a asp-controller="ProcessTemplateTasks"
                    asp-action="Delete" 
                    asp-route-id="@task.Id" 
                    class="btn btn-sm btn-outline-danger">Delete</a> 
        
                    <a asp-controller="ProcessTemplateTransitions" 
                    asp-action="Create" 
                       asp-route-fromTemplateTaskId="@task.Id"
                    class="btn btn-sm btn-outline-secondary">Add Transition</a>
                </div>    
            </div>
        </div>
        <div class="card-body">
            <p>@task.Description</p>
            <p>
                <strong>Approver team:</strong> @task.ApproverTeam &nbsp; 
                <strong>Approval required:</strong> @task.ApprovalRequired &nbsp;
                <strong>Sort order:</strong> @task.SortOrder
            </p>

            @if (task.Transitions != null && task.Transitions.Any())
            {
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Transition</th>
                            <th>Description</th>
                            <th></th>
            </tr>
                    </thead>
                    <tbody>
                        @foreach (var transition in task.Transitions)
                        {
                        <tr>
                            <td>@transition.DisplayLabel
                            @if (transition.IsDefault == true)
                            {
                                <span class="badge bg-success ms-1">Default</span>
                            }
                        <td>
                            @(transition.ToProcessTemplateTask?.Title ?? "End of process")
                        </td>

                        </td>                            
                            <td><a asp-controller="ProcessTemplateTransitions"
                                asp-action="Edit" 
                                asp-route-id="@transition.Id" 
                                class="btn btn-sm btn-outline-primary">Edit</a>
                                
                                <a asp-controller="ProcessTemplateTransitions" 
                                asp-action="Delete" 
                                asp-route-id="@transition.Id" 
                                class="btn btn-sm btn-outline-danger">Delete</a>
                            
                            </td>
                        </tr>
                        }
                    </tbody>
                    </table>
            }
    else
    {
        <p class="text-muted mb-0">No transitions added yet.</p>
    }
        </div>
    

   }
}
else 
{
    <p class="text-muted">No tasks added yet.</p>
}
<a asp-action="Index" class="btn btn-secondary mt-3">Back to list</a> 