@model VendorProcessManagerV1.Models.ProcessTemplate

@{
    ViewData["Title"] = "Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Details</h1>

<h2>@Model.Name</h2>
<p>@Model.Description</p>
<p>Created by: @Model.Creator.FirstName @Model.Creator.LastName</p>
<hr />
<div>
    <h4>Tasks</h4>
    <a asp-controller="ProcessTemplateTasks" 
        asp-action="Create" 
        asp-route-templateId="@Model.Id"
        class="btn btn-primary btn-sm mb-3">Add Task</a>
</div>
<div>
    <h4>Process Template</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Category)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Category)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Creator)
        </dt>
        <dd class = "col-sm-10">
            @* @Html.DisplayFor(model => model.Creator) *@
            @Model.Creator.FirstName @Model.Creator.LastName
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.CreateDate)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.CreateDate)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.IsActive)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.IsActive)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Version)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Version)
        </dd>
    </dl>
</div>
<div> 
    <a asp-action="StartInstance" 
        asp-controller="ProcessInstances" 
        asp-route-id="@Model.Id" 
        class="btn btn-success mb-3">Start Instance
    </a>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-2"><i class="bi bi-list-check"></i> Task List</h5>
        <a asp-controller="ProcessTemplateTasks" asp-action="Create" asp-route-templateId="@Model?.Id" class="btn btn-sm btn-success">
            <i class="bi bi-plus-circle"></i> Add Task
        </a>
    </div>
</div>

@if (Model.Tasks != null && Model.Tasks.Any())
{
    @foreach (var task in Model.Tasks.OrderBy(t => t.SortOrder))
    {
        <div class="card-mb-3 shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-2">
                <span class="badge bg-primary">@task.SortOrder</span>
                <strong>@task.Title</strong>
            </div>
                <div class="d-flex gap-2">
                    <a asp-controller="ProcessTemplateTasks"
                    asp-action="Edit"
                    asp-route-id="@task.Id"
                    class="btn btn-sm btn-outline-primary">Edit</a>
        
                    <a asp-controller="ProcessTemplateTasks"
                    asp-action="Delete" 
                    asp-route-id="@task.Id" 
                    class="btn btn-sm btn-outline-danger">Delete</a> 
        
                    <a asp-controller="ProcessTemplateTransitions" 
                    asp-action="Create" 
                       asp-route-fromTemplateTaskId="@task.Id"
                    class="btn btn-sm btn-outline-secondary">+ Transition</a>
                </div>    
            </div>
        </div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty(task.Description))
            {
                <p class="card-text text-muted small">@task.Description</p>
            }
            <div class="d-flex flex-wrap gap-2 align-items-center mt-2">
                @if (!string.IsNullOrEmpty(task.ApproverTeam))
                {
                    <span class="text-muted small">
                        Approver team: 
                        <strong class="text-dark">@task.ApproverTeam</strong>
                    </span>
                }
                @if (task.ApprovalRequired)
                {
                    <span class="badge bg-warning text-dark">
                        Approval required
                    </span>
                }
                else
                {
                    <span class="badge bg-secondary">No approval</span>
                }
                @if (!string.IsNullOrEmpty(task.DefaultOwnerRole))
                {
                    <span class="text-muted small">
                        Role: <strong class="text-dark">@task.DefaultOwnerRole</strong>

                    </span>
                }
            </div>
        </div>
        
        <div class="card-footer bg-light">
            <p class="text-muted small fw-semibold text-uppercase mb-2" 
                style="font-size:11px; letter-spacing:.05em;">
                Transitions
            </p>
            @if (task.Transitions != null && task.Transitions.Any())
            {
                @foreach (var transition in task.Transitions
                    .OrderBy(t => t.SortOrder))
                {
                    <div class="d-flex align-items-center gap-2 mb-2 flex-wrap">
                        <span class="text-muted">-></span>
                    <strong class="small">@transition.DisplayLabel</strong>
                    

                    @if (transition.IsDefault)
                    {
                        <span class="badge bg-success">Default</span>
                    }

                    @if(transition.ToProcessTemplateTask != null)
                    {
                        <span class="text-muted small">
                            -> @transition.ToProcessTemplateTask.Title
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger">End of process</span>
                    }

                    @if (!string.IsNullOrEmpty(transition.ConditionExpression))
                    {
                        <code class="small bg-white border rounded px-2 py-1">
                            @transition.ConditionExpression
                        </code>
                    }
                    <div class="ms-auto d-flex gap-1">
                        <a asp-controller="ProcessTemplateTransitions" 
                            asp-action="Edit"
                            asp-route-id="@transition.Id" 
                            class="btn btn-sm btn-outline-primary">
                            Edit
                        </a>
                        <a asp-controller="ProcessTemplateTransitions"
                           asp-action="Edit"
                           asp-route-id="@transition.Id"
                           class="btn btn-sm btn-outline-danger">
                           Delete
                       </a>
                    </div>
                </div>
                }
            }
            else
            {
                <p class="text-muted small fst-italic mb-0">
                    No transitions yet - task follows sort order automatically.
                </p>
            }
        </div>
       
    }
    
    

   }
}
else 
{
    <p class="text-muted">No tasks added yet.</p>
}
<a asp-action="Index" class="btn btn-secondary mt-3">Back to list</a> 