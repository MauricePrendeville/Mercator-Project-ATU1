@using Microsoft.AspNetCore.Mvc.Rendering
@model IEnumerable<VendorProcessManagerV1.Models.ProcessInstance>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Process Instances</h2>

<form asp-action="Index" method="get" class="row g-2 align-items-center mb-3">
    <input type="hidden" name="sortOrder" value="@ViewData["CurrentSort"]" />
        
    <div class="col-auto">
        <label class="col-form-label fw-bold">Filter by Approver Team:</label>
    </div>
    <div class="col-auto">
        <select name="teamFilter" class="form-select">
            <option value="">--AllTeams--</option>
            @foreach (var team in (SelectList)ViewData["TeamList"])
                {
                    if (team.Value == ViewData["CurrentFilter"]?.ToString())
                    {
                        <option value="@team.Value" selected>@team.Text</option>
                    }
                    else
                    {
                        <option value="@team.Value">@team.Text</option>
                    }
                }
            </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Filter</button>
        @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
            {
                <a asp-action="Index"
                    asp-route-sortOrder="@ViewData["CurrentSort"]"
                    class="btn btn-outline-secondary ms-2">Clear</a>
            }
    </div>
</form>

<table class="table">
    <thead>
        <tr>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["InstanceNameSort"]"
                       asp-route-teamFilter="@ViewData["CurrentFilter"]">
                            Instance Name
                    @if(ViewData["CurrentSort"]?.ToString() == "name_asc")
                    {
                        <span>upicon</span>
                    }
                    else if (ViewData["CurrentSort"]?.ToString() == "name.desc")
                    {
                        <span>downicon</span>
                    }
                </a>
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["TemplateSort"]"
                   asp-route-teamFilter="@ViewData["CurrentFilter"]">Template</a>
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["VendorSort"]"
                   asp-route-teamFilter="@ViewData["CurrentFilter"]">Vendor</a>
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["CreatedSort"]"
                   asp-route-teamFilter="@ViewData["CurrentFilter"]">Initiated By</a>
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["CreatedSort"]"
                   asp-route-teamFilter="@ViewData["CurrentFilter"]">Created</a>
            </th>            
            <th>
               <a asp-action="Index" asp-route-sortOrder="@ViewData["StatusSort"]"
                   asp-route-teamFilter="@ViewData["CurrentFilter"]">Status</a>
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) 
{
        <tr>                
            <td>
                @item.InstanceName
            </td>
            <td>
                @item.ProcessTemplate?.Name
            </td>
            <td>
                @item.VendorCandidate?.Name
            </td>
            
            <td>
                @item.InitiatedBy?.FirstName
                @item.InitiatedBy?.LastName
            </td>
            <td>
                @item.CreatedDate.ToShortDateString()
            </td>            
            
            <td>
                <span class="badge
                    @(item.Status == ProcessInstanceStatus.NotStarted ? "bg-secondary" :
                    item.Status == ProcessInstanceStatus.InProgress ? "bg-primary" :
                    item.Status == ProcessInstanceStatus.Completed ? "bg-success" : 
                    "bg-danger")">
                    @item.Status 
                </span>
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
