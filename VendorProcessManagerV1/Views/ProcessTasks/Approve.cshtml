@model VendorProcessManagerV1.ViewModels.ApproveTaskViewModel
@{ViewData ["Title"] = "Approve task"; }

<h2>Approve task</h2>

<div class="card mb-3">
    <div class="card-body w-75">
        <dl class="row mb-0">
            <dt class="col-sm-3">Task</dt>
            <dd class="col-sm-9"><strong>@Model.TaskTitle</strong></dd>

            <dt class="col-sm-3">Approver team</dt>
            <dd class="col-sm-9">
                <span class="badge bg-info">@Model.ApproverTeam</span>
            </dd>
        </dl>

    </div>
</div>

<form asp-action="Approve">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <input type="hidden" asp-for="TaskId" />
    <input type="hidden" asp-for="ProcessInstanceId" />
    <input type="hidden" asp-for="TaskTitle" />
    <input type="hidden" asp-for="ApproverTeam" />
    
    <div class="form-group">
        <label asp-for="Decision" class="control-label">Decision</label>
        <select asp-for="Decision"
                asp-items="Model.DecisionOptions"
                class="form-control">
        </select>
        <span asp-validation-for="Decision" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Notes" class="control-label">Notes</label>
        <textarea asp-for="Notes"
            class="form-control"
            rows="3"
            placeholder="Optional notes about this decision">
        </textarea>
    </div>

    <button type="submit" class="btn btn-primary">Submit Decision</button>
    <a asp-action="Details"
        asp-controller="ProcessInstances"
        asp-route-id="@Model.ProcessInstanceId"
        class="btn btn-secondary">Cancel</a>
</form>

        @section Scripts{
            @{
                await Html.RenderPartialAsync("_ValidationScriptsPartial"); 
            }
        }