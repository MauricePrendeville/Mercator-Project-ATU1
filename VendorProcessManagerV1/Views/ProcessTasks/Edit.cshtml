@model VendorProcessManagerV1.ViewModels.EditProcessTaskViewModel

@{
    ViewData["Title"] = "Edit task";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Edit task</h2>

<form asp-action="Edit">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ProcessInstanceId" />
    <input type="hidden" asp-for="Title" />
    <input type="hidden" asp-for="SortOrder" />
    <input type="hidden" asp-for="ApprovalRequired" />
    <input type="hidden" asp-for="ApproverTeam" />


<div class="card mb-3">
    <div class="card-header">Task details</div>
    <div class="card-body"> 
        <dl class="row mb-0">
            <dt class="col-sm-3">Title</dt>
            <dd class="col-sm-9">@Model.Title</dd>
                
            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.Description</dd>

            <dt class="col-sm-3">Sort Order</dt>
            <dd class="col-sm-9">@Model.SortOrder</dd>

            <dt class="col-sm-3">Approver Team</dt>
            <dd class="col-sm-9">@Model.ApproverTeam</dd>

            <dt class="col-sm-3">Approval Required</dt>
            <dd class="col-sm-9">@Model.ApprovalRequired</dd>
        </dl>
    </div>
</div>
<div class="card mb-3">
    <div class="card-header">Execution</div>
    <div class="card-body">

        <div class="form-group">
            <label asp-for="OwnerId" class="control-label">Owner</label>
            <select asp-for="OwnerId"
                    asp-items="Model.OwnerOptions"
                    class="form-control">
                    <option value="">--Unassigned--</option>
                </select>
                <span asp-validation-for="OwnerId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="ProcessTaskStatus" class="control-label">
                Status
            </label>
            <select asp-for="ProcessTaskStatus" 
                    asp-items="Model.StatusOptions" 
                    class="form-control">
            </select>
            <span asp-validation-for="ProcessTaskStatus" 
                class="text-danger">
            </span>
        </div>

        <div class="form-group">
            <label asp-for="TaskNotes" class="control-label">
                Task notes
            </label>
            <textarea asp-for="TaskNotes"
                      class="form-control"
                      rows="3"></textarea>
            <span asp-validation-for="StartedDate" class="text-danger"></span>
        </div>



    </div>
</div>
            
            
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="IsCompleted" /> @Html.DisplayNameFor(model => model.IsCompleted)
                </label>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="ApprovalRequired" /> @Html.DisplayNameFor(model => model.ApprovalRequired)
                </label>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
